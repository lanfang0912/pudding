{
  "rules": {
    "orders": {
      ".read": "auth != null",
      "$orderId": {
        ".write": "auth != null || !data.exists()"
      }
    },
    "settings": {
      "maxPerDay":     { ".read": "auth != null", ".write": "auth != null" },
      "prodOverrides": { ".read": "auth != null", ".write": "auth != null" },
      "$other":        { ".read": "auth != null", ".write": "auth != null" }
    },
    "articles": {
      ".read": true,
      "$articleId": { ".write": "auth != null" }
    },
    "surveys": {
      "responses": {
        ".read": "auth != null",
        ".write": true
      }
    },
    "bakery": {
      "events": {
        ".read": true,
        "$eventId": { ".write": "auth != null" }
      },
      "registrations": {
        ".read": "auth != null",
        "$eventId": {
          "$regId": { ".write": "auth != null || !data.exists()" }
        }
      }
    }
  }
}
